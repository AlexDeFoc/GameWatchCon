            }
        },
        {
            "name": "ClangCL Compiler Base",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang-cl",
                "CMAKE_CXX_COMPILER": "clang-cl"
            }
        },
        {
            "name": "Generic Base",
            "hidden": true,
            "inherits": "VCPKG Base",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "OFF"
            }
        },
        {
            "name": "Export Compile CMDS to file",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON" 
            }
        },
        {
            "name": "Debug Build Base",
            "hidden": true,
