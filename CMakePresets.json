            "architecture": {
                "value": "x64",
                "strategy": "set"
            }
        },
        {
            "name": "Arch External",
            "hidden": true,
            "architecture": {
                "value": "x64",
                "strategy": "external"
            }
        },
        {
            "name": "VCPKG Base",
            "hidden": true,
            "cacheVariables": {
                "VCPKG_MANIFEST_MODE": "ON",
                "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_packages",
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            },
            "environment": {
                "VCPKG_BINARY_SOURCES": "clear;files,${sourceDir}/.vcpkg_cache,readwrite"
            }
        },
        {
            "name": "VCPKG - Release Windows",
